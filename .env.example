# Set ONE provider to enable the "after LLM" answer. Without a key, the API
# still returns the "before LLM" (retrieval) answer. Priority: OpenRouter > Groq > Claude.

# OpenRouter — https://openrouter.ai/keys  (OpenAI-compatible gateway)
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=openai/gpt-4o        # optional; any OpenRouter model id
# OPENROUTER_SITE_NAME=CV RAG Q&A       # optional; shown in OpenRouter dashboard

# Groq (free) — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
